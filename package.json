{
  "name": "blog-astro",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "run-s check \"build-ci {@}\" --",
    "build-ci": "astro build",
    "check": "astro check",
    "dev": "astro dev",
    "lint": "run-s \"lint:biome {@}\" lint:md --",
    "lint:biome": "biome check",
    "lint:md": "remark . --frail",
    "preview": "astro preview"
  },
  "remarkConfig": {
    "plugins": [
      "remark-mdx",
      "remark-frontmatter",
      "remark-preset-lint-consistent",
      "remark-preset-lint-recommended",
      "remark-preset-lint-markdown-style-guide",
      [
        "remark-lint-maximum-line-length",
        false
      ],
      [
        "remark-lint-ordered-list-marker-value",
        "ordered"
      ]
    ]
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@fontsource-variable/fira-code": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "astro": "^6.3.3",
    "astro-expressive-code": "^0.42.0",
    "astro-min": "1.3.1",
    "astro-purgecss": "^6.0.1",
    "date-fns": "4.1.0",
    "katex": "^0.16.46",
    "lxgw-wenkai-screen-webfont": "^1.7.0",
    "mermaid": "^11.15.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-mermaid": "^3.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-smartypants": "^3.0.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/markdown-remark": "^7.1.2",
    "@biomejs/biome": "^2.4.15",
    "@playwright/browser-chromium": "^1.60.0",
    "autoprefixer": "^10.5.0",
    "browserslist": "^4.28.2",
    "cssnano": "^8.0.1",
    "image-size": "^2.0.2",
    "npm-run-all2": "^8.0.4",
    "playwright": "^1.60.0",
    "postcss": "^8.5.14",
    "postcss-html": "^1.8.1",
    "postcss-preset-env": "^11.3.0",
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-lint-maximum-line-length": "^4.1.1",
    "remark-lint-ordered-list-marker-value": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-preset-lint-consistent": "^6.0.1",
    "remark-preset-lint-markdown-style-guide": "^6.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "sharp": "^0.34.5",
    "stylelint": "^17.11.1",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^8.0.13"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
