{
  "name": "blog-astro",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "run-s check \"build-ci {@}\" --",
    "build-ci": "astro build",
    "check": "astro check",
    "dev": "astro dev",
    "lint": "run-s \"lint:biome {@}\" lint:md --",
    "lint:biome": "biome check",
    "lint:md": "remark . --frail",
    "preview": "astro preview"
  },
  "remarkConfig": {
    "plugins": [
      "remark-mdx",
      "remark-frontmatter",
      "remark-preset-lint-consistent",
      "remark-preset-lint-recommended",
      "remark-preset-lint-markdown-style-guide",
      [
        "remark-lint-maximum-line-length",
        false
      ],
      [
        "remark-lint-ordered-list-marker-value",
        "ordered"
      ]
    ]
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@fontsource-variable/fira-code": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "astro": "^6.1.7",
    "astro-expressive-code": "^0.41.7",
    "astro-min": "1.3.1",
    "astro-purgecss": "^6.0.1",
    "date-fns": "4.1.0",
    "katex": "^0.16.45",
    "lxgw-wenkai-screen-webfont": "^1.7.0",
    "mermaid": "^11.14.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-mermaid": "^3.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-smartypants": "^3.0.2",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/markdown-remark": "^7.1.0",
    "@biomejs/biome": "^2.4.12",
    "@playwright/browser-chromium": "^1.59.1",
    "autoprefixer": "^10.5.0",
    "browserslist": "^4.28.2",
    "cssnano": "^7.1.5",
    "image-size": "^2.0.2",
    "npm-run-all2": "^8.0.4",
    "playwright": "^1.59.1",
    "postcss": "^8.5.10",
    "postcss-html": "^1.8.1",
    "postcss-preset-env": "^11.2.1",
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-lint-maximum-line-length": "^4.1.1",
    "remark-lint-ordered-list-marker-value": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-preset-lint-consistent": "^6.0.1",
    "remark-preset-lint-markdown-style-guide": "^6.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "sharp": "^0.34.5",
    "stylelint": "^17.8.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^8.0.8"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
